rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── Users ───────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      // Users can update their own non-sensitive fields only
      allow update: if (isOwner(uid) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'referralCount', 'totalEarnings'])) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Products ────────────────────────────────────────────────────
    match /products/{productId} {
      allow read:   if true;  // Public catalog
      allow create, update, delete: if isAdmin();
    }

    // ── Orders ──────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Owner can read their own orders
      allow read:   if isSignedIn() && resource.data.userId == request.auth.uid || isAdmin();
      // Orders are only created/updated via server (API routes)
      allow create, update, delete: if false;
    }

    // ── Referrals ───────────────────────────────────────────────────
    match /referrals/{referralId} {
      allow read:   if isSignedIn() && resource.data.affiliateUid == request.auth.uid || isAdmin();
      allow create, update, delete: if false;  // Server-only
    }

    // ── Settings ────────────────────────────────────────────────────
    match /settings/{doc} {
      allow read:   if true;
      allow write:  if isAdmin();
    }

    // ── Contacts ────────────────────────────────────────────────────
    match /contacts/{contactId} {
      allow read:   if isAdmin();
      allow create: if true;  // Public form
      allow update, delete: if isAdmin();
    }

    // ── Milestones ──────────────────────────────────────────────────
    match /milestones/{milestoneId} {
      allow read:   if isSignedIn() && resource.data.affiliateUid == request.auth.uid || isAdmin();
      allow write:  if false;  // Server-only
    }

    // ── Coupons ──────────────────────────────────────────────────────
    match /coupons/{couponId} {
      allow read:   if isSignedIn() && resource.data.userId == request.auth.uid || isAdmin();
      allow write:  if false;  // Server-only
    }

    // ── Payout Requests ─────────────────────────────────────────────
    // Only admins can view payout requests; created server-side only
    match /payout_requests/{requestId} {
      allow read:   if isAdmin();
      allow write:  if false;  // Server-only
    }

    // ── Secure Payout Details (subcollection under users) ───────────
    // Bank account details stored in a separate restricted subcollection
    match /users/{uid}/secure_payout_details/{doc} {
      allow read:   if isAdmin();
      allow write:  if isOwner(uid) || isAdmin();
    }
  }
}
